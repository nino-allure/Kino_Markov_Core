<Page x:Class="Kino_Markov.Pages.Clubs.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Kino_Markov.Pages.Clubs"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid>
        <Grid Margin="20" Background="#FFF0F0F0">
            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Width="80" Height="80" VerticalAlignment="Top" Margin="0,20,0,0" Source="/Images/club.png"/>
                <Button Click="AddClick" Height="25" Content="Добавить" VerticalAlignment="Top" Margin="10,110,10,0"
                Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White" x:Name="BtnAdd"/>
                <Label Content="Наименование: " VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,20,0,0" Grid.Column="1"/>
                <TextBox x:Name="Name" Text="" VerticalAlignment="Top" Margin="10,50,10,0" Height="25" VerticalContentAlignment="Center" Grid.Column="1"/>
                <Label Content="Адрес: " VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,80,0,0" Grid.Column="1"/>
                <TextBox x:Name="Address" Text="" VerticalAlignment="Top" Margin="10,110,10,0" Height="25" VerticalContentAlignment="Center" Grid.Column="1"/>
                <Label Content="Время работы: " VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,20,0,0" Grid.Column="2"/>
                <TextBox x:Name="WorkTime" Text="" VerticalAlignment="Top" Margin="10,50,10,1" Height="82" VerticalContentAlignment="Center"  Grid.Column="21"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
