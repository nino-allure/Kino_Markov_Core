<Page x:Class="Kino_Markov.Pages.Users.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Kino_Markov.Pages.Users"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid>
        <Grid Margin="20" Background="#FFF0F0F0">
            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Width="80" Height="80" VerticalAlignment="Top" Margin="0,20,0,0" Source="/Images/user.png"/>
                <Button Click="BtnAdd" Height="25" Content="Изменить" VerticalAlignment="Top" Margin="10,110,10,0"
            Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White" x:Name="BtnAdd"/>
                <Label Content="Дата аренды: " VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,20,0,0" Grid.Column="1"/>
                <DatePicker x:Name="RentStart" Text="" VerticalAlignment="Top" Margin="10,50,10,0" Height="25" VerticalContentAlignment="Center" IsEnabled="False" Grid.Column="1"/>
                <Label Content="Время Аренды: " VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,80,0,0" Grid.Column="1"/>
                <TextBox x:Name="RentTime" Text="" VerticalAlignment="Top" Margin="10,110,10,0" Height="25" VerticalContentAlignment="Center" IsEnabled="False" Grid.Column="1"/>
            </Grid>
            <Label Content="Продолжительность: " VerticalAlignment="Top" HorizontalAlignment="Left" Margin="460,32,0,0" Grid.Column="2"/>
            <TextBox x:Name="Duration" Text="" VerticalAlignment="Top" Margin="460,62,10,0" Height="25" VerticalContentAlignment="Center" IsEnabled="False" Grid.Column="2"/>
            <Label Content="Клуб: " VerticalAlignment="Top" HorizontalAlignment="Left" Margin="460,92,0,0"/>
            <ComboBox x:Name="Clubs" Text="" VerticalAlignment="Top" Margin="460,122,10,0" Height="25" VerticalContentAlignment="Center" IsEnabled="False" Grid.Column="2"/>
            <Label Content="Фамилия Имя и Отчество: " VerticalAlignment="Top" HorizontalAlignment="Left" Margin="140,161,0,0"/>
            <TextBox x:Name="FIO" Text="" VerticalAlignment="Center" Margin="140,0,10,0" Height="26" VerticalContentAlignment="Center" IsEnabled="False"/>
        </Grid>
    </Grid>
</Page>
